# TUDOaqui API - Environment Variables
# Copie este ficheiro para .env e configure os valores

# App
APP_NAME=TUDOaqui API
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tudoaqui

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - SEGURANÇA
# IMPORTANTE: Gere uma chave segura com: python -c "import secrets; print(secrets.token_urlsafe(64))"
# NUNCA use o valor default em produção!
SECRET_KEY=CHANGE_ME_GENERATE_SECURE_KEY_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3

# SMS Provider (mock | africastalking)
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER=TUDOaqui

# Africa's Talking - SMS Provider para Angola
# Obter credenciais em: https://africastalking.com/
# 1. Criar conta e verificar email
# 2. Ir em Settings -> API Key
# 3. Copiar API Key e Username
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_SANDBOX=true

# Tuendi Config (valores em Kz)
TAXA_PLATAFORMA=0.20
PRECO_BASE_KM=150
PRECO_BASE_MINUTO=50
TAXA_MINIMA=500
RAIO_BUSCA_MOTORISTAS=5000

# Payments
MULTICAIXA_API_URL=
MULTICAIXA_API_KEY=
MOBILEMONEY_API_URL=
MOBILEMONEY_API_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
