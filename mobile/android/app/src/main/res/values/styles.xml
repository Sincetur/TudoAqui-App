<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema da app TUDOaqui -->
    <style name="Theme.TUDOaqui" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/statusBarColor</item>
        <item name="android:navigationBarColor">@color/navigationBarColor</item>
        <item name="android:windowBackground">@color/splashBackground</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.TUDOaqui.Splash" parent="Theme.TUDOaqui">
        <item name="android:windowBackground">@color/splashBackground</item>
    </style>
</resources>
