# =============================================
# TUDOaqui — Variáveis de Produção
# Copiar para .env.production e preencher
# Este ficheiro é enviado por scp durante o deploy
# =============================================

# === Base de Dados ===
DB_PASSWORD=SENHA_FORTE_AQUI

# === JWT (gerar: openssl rand -hex 32) ===
SECRET_KEY=GERAR_COM_openssl_rand_hex_32

# === Africa's Talking (SMS OTP) ===
AFRICASTALKING_API_KEY=SUA_KEY_AQUI
AFRICASTALKING_USERNAME=SEU_USERNAME_AQUI
AFRICASTALKING_SANDBOX=false

# === Google Maps (para backend se necessário) ===
# GOOGLE_MAPS_API_KEY=SUA_KEY_AQUI
